WINSTALL_APP_TAG=winstall/app-2.0.0 # Comment this will use winstall/app-latest

# Required for authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_TRUST_HOST=true

NEXT_PUBLIC_TWITTER_LOGIN=true

# Twitter API Bearer Token (for fetching user data)
TWITTER_BEARER=your-twitter-bearer-token

# Twitter OAuth 2.0 Credentials
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# Winstall API Configuration (Runtime - NOT used during build)
# These variables are read at runtime only, ensuring the Docker image is environment-agnostic.
# Used by backend (SSR/ISR) to directly access API server
WINSTALL_API_BASE=http://localhost:3100
WINSTALL_API_KEY=your-api-key
WINSTALL_API_SECRET=your-api-secret

# Exposed to client (CSR) via /api/config for browser to fetch icon URLs, if not set will auto fallback to WINSTALL_API_BASE
NEXT_PUBLIC_WINSTALL_API_BASE=http://localhost:3100

# Optional: API debugging and timeout
WINSTALL_API_DEBUG=0
WINSTALL_API_TIMEOUT_MS=15000

# Node Environment
NODE_ENV=development
