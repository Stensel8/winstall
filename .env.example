#WINSTALL_APP_TAG=app-2.0.0 # Comment this will use app-latest

# Required for authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_TRUST_HOST=true

# Twitter OAuth 1.0a Credentials
TWITTER_ID=your-twitter-consumer-key
TWITTER_SECRET=your-twitter-consumer-secret

# Twitter API Bearer Token (for fetching user data)
TWITTER_BEARER=your-twitter-bearer-token

# Winstall API Configuration (Runtime)
WINSTALL_API_BASE=http://localhost:3100
WINSTALL_API_KEY=your-api-key
WINSTALL_API_SECRET=your-api-secret

# Optional: API debugging and timeout
WINSTALL_API_DEBUG=0
WINSTALL_API_TIMEOUT_MS=15000

# Node Environment
NODE_ENV=development
